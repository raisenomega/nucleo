# =============================================================================
# NÚCLEO by raisen — .gitignore MAESTRO
# Aplica la declaración de MAIN-PROTECTOR.md (v1.1)
# =============================================================================

# --- Regla catch-all para documentos fundamentales de NÚCLEO -----------------
# Cualquier .md con sufijo -NUCLEO / _NUCLEO queda protegido automáticamente.
# También cualquier archivo bajo docs-nucleo/ en cualquier profundidad.
*-NUCLEO.md
*_NUCLEO.md
*.nucleo.md
# NUCLEO en CUALQUIER posición del nombre, no solo como sufijo: ERP-NUCLEO-COMPLETO.md se colaba por las
# tres reglas de arriba. Verificado que ningún .md rastreado encaja (solo hay 4 README).
*NUCLEO*.md
*nucleo*.md
docs-nucleo/
**/docs-nucleo/

# --- Documentos fundamentales listados explícitamente ------------------------
# (redundante con la catch-all, pero explícito por claridad y para docs con
#  nombres que no siguen la convención de sufijo)
metodo-nucleo.md
PRD_nucleo.md
PRD-nucleo.md
SOURCE_OF_TRUTH.md
Estado_Nucleo.md
Estado-Nucleo.md
CLAUDE.md
MAIN-PROTECTOR.md
TEMA-*.md
PROTOCOLO-*.md
SEGURIDAD-*.md
ESQUEMA-*.md
AGENT-TEAMS-*.md
DDD-*.md
Trilogy_Model_Price.md
PACKAGE-*.md

# --- Ecosistema Claude Code (revela reglas y acciones) -----------------------
.claude/
CLAUDE.md

# --- Overrides de identidad git (viven en $HOME, no en el repo) --------------
.gitconfig-raisen
.gitconfig-*

# --- Secretos y variables de entorno -----------------------------------------
.env
.env.local
.env.*.local
.env.supabase
!.env.example

# --- Supabase (config e info de proyecto — local por instancia) --------------
supabase/config.toml
supabase/.temp/
supabase/.branches/

# --- Directorios de trabajo / build ------------------------------------------
node_modules/
.next/
.vite/
.vercel/
.output/
.tanstack/
dist/
build/
coverage/
*.tsbuildinfo

# --- Autogenerado por TanStack Start (no se commitea; lo regenera el build) ---
apps/web/src/routeTree.gen.ts
**/routeTree.gen.ts

# --- Editor / SO -------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
!.vscode/settings.example.json
.idea/

# --- Logs / cache ------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python
__pycache__/
*.pyc

# Service Workers generados por scripts/inject-sw-version.mjs (templates en apps/web/sw-src/)
apps/web/public/service-worker.js
apps/web/public/service-worker-public.js

